    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst allResults = [];\n\nfunction parseRichText(text) {\n  if (!text) return [];\n  const parts = text.split(/(\\*\\*.*?\\*\\*)/g);\n  return parts.map(part => {\n    if (part === '') return null;\n    if (part.startsWith('**') && part.endsWith('**')) {\n      return { type: 'text', text: { content: part.slice(2, -2) }, annotations: { bold: true } };\n    }\n    return { type: 'text', text: { content: part } };\n  }).filter(item => item !== null);\n}\n\nfor (let idx = 0; idx < items.length; idx++) {\n  const chunks = items[idx].json.content_chunks || [];\n  const fullContent = chunks.join('');\n  const lines = fullContent.split('\\n');\n  const blocks = [];\n\n  for (let line of lines) {\n    line = line.trim();\n    if (line === '') continue;\n    if (line.startsWith('# ')) {\n      blocks.push({ object: 'block', type: 'heading_1', heading_1: { rich_text: parseRichText(line.replace('# ', '').substring(0, 2000)) } });\n    } else if (line.startsWith('## ')) {\n      blocks.push({ object: 'block', type: 'heading_2', heading_2: { rich_text: parseRichText(line.replace('## ', '').substring(0, 2000)) } });\n    } else if (line.startsWith('### ')) {\n      blocks.push({ object: 'block', type: 'heading_3', heading_3: { rich_text: parseRichText(line.replace('### ', '').substring(0, 2000)) } });\n    } else if (line.startsWith('- ') || line.startsWith('* ')) {\n      blocks.push({ object: 'block', type: 'bulleted_list_item', bulleted_list_item: { rich_text: parseRichText(line.replace(/^[-*] /, '').substring(0, 2000)) } });\n    } else if (/^\\d+\\.\\s/.test(line)) {\n      blocks.push({ object: 'block', type: 'numbered_list_item', numbered_list_item: { rich_text: parseRichText(line.replace(/^\\d+\\.\\s/, '').substring(0, 2000)) } });\n    } else {\n      for (let i = 0; i < line.length; i += 2000) {\n        blocks.push({ object: 'block', type: 'paragraph', paragraph: { rich_text: parseRichText(line.slice(i, i + 2000)) } });\n      }\n    }\n  }\n  allResults.push({ json: { blocks_array: blocks } });\n}\n\nreturn allResults;"
      },

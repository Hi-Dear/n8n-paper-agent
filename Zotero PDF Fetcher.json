    {
      "parameters": {
        "jsCode": "const MAX_LENGTH = 2000;\nconst llmItems = $('Basic LLM Chain').all();\nconst results = [];\n\nfor (let i = 0; i < llmItems.length; i++) {\n  const llmOutput = llmItems[i].json.output || {};\n  const content = llmOutput.content || \"\";\n\n  const chunks = [];\n  for (let j = 0; j < content.length; j += MAX_LENGTH) {\n    chunks.push(content.slice(j, j + MAX_LENGTH));\n  }\n\n  results.push({\n    json: {\n      output: llmOutput,\n      content_chunks: chunks,\n      is_split: content.length > MAX_LENGTH\n    }\n  });\n}\n\nreturn results;"
      },
